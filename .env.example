# ─── Nyx · chaves de provider ───────────────────────────────────────────────
# Copie este arquivo para `.env` e preencha só as que você usa.
# Você NÃO precisa de todas — o Nyx é provider-agnostic: basta uma.

# OpenAI  → https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter (acesso a centenas de modelos com uma chave só) → https://openrouter.ai/keys
OPENROUTER_API_KEY=

# NVIDIA NIM / build.nvidia.com → https://build.nvidia.com
NVIDIA_API_KEY=

# Anthropic (Claude) → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Padrões opcionais ──────────────────────────────────────────────────────
# Provider e modelo usados quando você não passa --provider / --model.
NYX_DEFAULT_PROVIDER=openrouter
NYX_DEFAULT_MODEL=
